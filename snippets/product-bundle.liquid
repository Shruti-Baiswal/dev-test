{% if product.template_suffix == 'bundle' %}

{% for block in section.blocks %}
  {% case block.type %}
    {% when 'second_text' %}
      <div class="second-block" style="background-color: {{ block.settings.bg_color }};">
        {% if block.settings.icon_left != blank %}
          <img src="{{ block.settings.icon_left | img_url: '32x32' }}" alt="Dots Icon" class="stepzz-icon-left">
        {% endif %}
        <span class="growth-text" style="color: {{ block.settings.text_color }};">
          {{ block.settings.text_center }}
        </span>
        {% if block.settings.icon_right != blank %}
          <img src="{{ block.settings.icon_right | img_url: '32x32' }}" alt="Dots Icon" class="stepzz-icon-right">
        {% endif %}
      </div>

    {% when 'feature_points' %}
  <div class="feature-list">
  {% for i in (1..3) %}
    {% assign point_key = 'point_' | append: i %}
    {% assign point = block.settings[point_key] %}
    {% if point != blank %}
      <div class="feature-item">
        <span class="feature-icon">✔</span>
        <span class="feature-text">{{ point }}</span>
      </div>
    {% endif %}
  {% endfor %}
</div>
  {% endcase %}
{% endfor %}

{% assign buttons = "btn1,btn2,btn3" | split: "," %}

<div class="bundle-buttons">
  {% for btn in buttons %}
    {% assign btn_product = null %}
    {% assign btn_text = null %}

    {% for block in section.blocks %}
      {% assign product_key = btn | append: "_product" %}
      {% assign text_key = btn | append: "_text" %}
      {% if block.settings[product_key] != blank %}
        {% assign btn_product = block.settings[product_key] %}
        {% assign btn_text = block.settings[text_key] %}
      {% endif %}
    {% endfor %}
    {% if btn_product %}
      <button
        type="button"
        class="bundle-btn"
        data-button="{{ btn }}"
        data-product-handle="{{ btn_product.handle }}"
        data-product-title="{{ btn_product.title | escape }}"
        data-product-image="{{ btn_product.featured_image | img_url: '1024x1024' }}"
        data-product-price="{{ btn_product.price | money }}"
        data-product-compare-price="{% if btn_product.compare_at_price > btn_product.price %}{{ btn_product.compare_at_price | money }}{% endif %}"
        data-variant-id="{{ btn_product.variants.first.id }}"
        data-free-gift="{{ btn_product.metafields.custom.free_gift.value.selected_or_first_available_variant.id }}"
        data-gift-img-one="{{ btn_product.metafields.custom.pair_offer_img_one | img_url: '400x400' }}"
        data-gift-title-one="{{ btn_product.metafields.custom.pair_offer_title_one }}"
        data-gift-img-two="{{ btn_product.metafields.custom.pair_offer_img_two | img_url: '400x400' }}"
        data-gift-title-two="{{ btn_product.metafields.custom.pair_offer_title_two }}"
      >
        {{ btn_text }}
      </button>
    {% endif %}
  {% endfor %}
</div>


<div class="giftbox-block">
                      <!-- Image -->
                      <img
                        src="{{ block.settings.pair_giftbox | img_url: '500x' }}"
                        alt="{{ block.settings.gift_bold_text | escape }}"
                        class="giftbox-image"
                      >

                      {% if block.settings.gift_bold_text %}
                        <div class="giftbox-text">
                          <strong>{{ block.settings.gift_bold_text }}</strong>
                        </div>
                      {% endif %}
                    </div>

<div class="gift-boxes-wrapper">

  <div class="gift-box shipping-box locked">
    <div class="discount-badge">20% OFF</div>
    <img src="" alt="">
    <h4 class="gift-title"></h4>
  </div>

  <div class="gift-box free-gift-box locked">
    <div class="freegift-badge"></div>
    <img src="" alt="">
    <h4 class="gift-title"></h4>
  </div>

</div>




<div class="bundle-price-box">

  <div class="bundle-price-left">

    {% render 'price', product: product %}

    <span class="bundle-offer-text">
      Get The Offer Today
    </span>

  </div>

  <div class="bundle-save">
    <span>You Save Rs.</span>
    <span id="saveAmount">0.00</span>
  </div>

</div>



{% for btn in buttons %}

 {% assign product_key = btn | append: "_product" %}
{% assign btn_product = block.settings[product_key] %}

{% if btn_product %}

<div class="bundle-group" data-handle="{{ btn_product.handle }}">

{% for pair in btn_product.metafields.custom.bundle_pair.value %}

{% assign pair_product = pair.product.value %}

<div class="bundle-box" data-product='{
  "variants": [
    {% for v in pair_product.variants %}
      {
        "id": {{ v.id }},
        "option1": {{ v.option1 | json }},
        "option2": {{ v.option2 | json }},
        "image": {{ v.featured_image.src | img_url: '500x500' | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}'>
<span class="pair-label">{{ pair.pair_label }}</span>

<div class="bundle-card">

<div class="pair-top">
<span class="edit-text">Edit</span>
</div>

<div class="card-body">

<img class="preview-image" src="" />

<div class="preview-size preview-text">White (S)</div>

</div>

</div>

</div>

{% endfor %}

</div>



{% endif %}

{% endfor %}

{% assign first_pair = btn_product.metafields.custom.bundle_pair.value.first %}
{% assign selector_product = first_pair.product.value %}

<div class="bundle-selector">
<div class="heading_txt">
<h3>Select your options:</h3>
</div>

{% for option in pair_product.options_with_values %}
{% if option.name == 'Color' %}
<h4 class="color-heading">
COLOUR: <span class="selected-color"></span>
</h4>

<div class="color-options">

{% for value in option.values %}

<label class="color-circle">

<input
type="radio"
name="color-{{ btn_product.handle }}-{{ pair_product.id }}-{{ pair.id }}"
value="{{ value }}"
hidden
>

<span class="color-dot"
style="
{% if value.swatch.image %}
background-image:url({{ value.swatch.image | image_url: width: 100 }});
background-size:cover;
{% else %}
background-color: {{ value.swatch.color }};
{% endif %}
">
<span class="tick"><i class="fa-solid fa-circle-check"></i></span>
</span>
</label>

{% endfor %}

</div>

{% endif %}
{% endfor %}


{% for option in pair_product.options_with_values %}
{% if option.name == 'Size' %}

<div class="size-options">

{% for value in option.values %}

<label>

<input
type="radio"
name="size-{{ btn_product.handle }}-{{ pair_product.id }}-{{ pair.id }}"
value="{{ value }}"
>

{{ value }}

</label>

{% endfor %}

</div>

{% endif %}
{% endfor %}

<div class="bundle-message" id="bundleMessage"></div>
</div>


{% endif %}