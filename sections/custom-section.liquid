<div>
  {% comment %} <h2>{{ section.settings.heading }}</h2> {% endcomment %}
  <p>{{ section.settings.text }}</p>
</div>
{% render 'heading', text: section.settings.heading %}

{% schema %}
{
  "name": "Custom Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "My Custom Section"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "This is my first section created."
    }
  ],
  "presets": [
    {
      "name": "Custom Section"
    }
  ]
}
{% endschema %}
